# AI Studio API configuration
# Copy this file to .env for local Docker Compose usage.
# In 1Panel, enter these values in the Compose environment instead.

# Required for public deployment. Use at least 32 random characters.
AISTUDIO_API_KEY=replace-with-a-long-random-token

# Host port bound only to 127.0.0.1. Let 1Panel reverse proxy this port.
AISTUDIO_BIND_PORT=8080

# Optional outbound proxy used by the browser.
# Example: http://user:password@proxy.example.com:8080
AISTUDIO_PROXY=

# This VPS profile is designed for one request at a time.
AISTUDIO_MAX_CONCURRENCY=1

# Override the image to pin or roll back a release.
# AISTUDIO_IMAGE=ghcr.io/dreamdana88/aistudio-api:1.0.0

# Browser settings
AISTUDIO_BROWSER=chromium
AISTUDIO_BROWSER_HEADLESS=1

# Model defaults
AISTUDIO_DEFAULT_TEXT_MODEL=gemma-4-31b-it
AISTUDIO_DEFAULT_IMAGE_MODEL=gemini-3.1-flash-image-preview

# Timeouts and cache
AISTUDIO_TIMEOUT_REPLAY=120
AISTUDIO_TIMEOUT_STREAM=120
AISTUDIO_TIMEOUT_CAPTURE=30
AISTUDIO_SNAPSHOT_CACHE_TTL=3600
AISTUDIO_SNAPSHOT_CACHE_MAX=100

# Account rotation
AISTUDIO_ACCOUNT_ROTATION_MODE=round_robin
AISTUDIO_ACCOUNT_COOLDOWN_SECONDS=60
AISTUDIO_ACCOUNT_MAX_RETRIES=3

# Debugging
AISTUDIO_DUMP_RAW_RESPONSE=0
AISTUDIO_DUMP_RAW_RESPONSE_DIR=/tmp
